GITHUB_TOKEN=            # classic PAT, no scopes needed (public data)
DATABASE_URL=            # Neon POOLED connection string (host has -pooler)
STARS_MIN=100
POLL_INTERVAL_SECONDS=180
BACKFILL_HOURS=24
LANGUAGES=javascript,typescript,python,go,rust,java
LABEL_FILTER=            # optional CSV, e.g. good first issue,help wanted
FEED_PAGE_SIZE=50
PORT=3000               # read API port (npm run api)
POLL_TRIGGER_TOKEN=     # optional shared secret; enables POST /internal/poll for external cron pingers
ENRICH_MAX_ISSUES=500   # max issues re-verified per enrich run
RETENTION_DAYS=5        # delete issues older than this (retention runs with enrich)
